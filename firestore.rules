rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // MVP development rules. Tighten before production with verified roles.
    match /helpRequests/{requestId} {
      allow create: if true;
      allow read, update: if request.auth != null;
      allow delete: if false;
    }

    match /professionals/{professionalId} {
      allow create: if request.auth != null && request.auth.uid == professionalId;
      allow read: if true;
      allow update: if request.auth != null && request.auth.uid == professionalId;
      allow delete: if false;
    }
  }
}
